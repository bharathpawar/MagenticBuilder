# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://emersion-openai-project-resource.services.ai.azure.com/api/projects/emersion-openai-project


# This is the *deployment name*, NOT the model name
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Agent config
AI_FOUNDRY_AGENT_NAME= workflow-agent
AI_FOUNDRY_AGENT_INSTRUCTIONS=You are a helpful assistant that answers Microsoft documentation questions.
AZURE_OPENAI_API_KEY = undefined

